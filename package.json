{
  "name": "codex-account",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cli": "bun ./src/main.ts",
    "build:ui-css": "tailwindcss -i src/web/globals.css -o src/web/static/alignui.css --minify",
    "build:ui": "bun run build:ui-css && vite build",
    "watch:ui-css": "tailwindcss -i src/web/globals.css -o src/web/static/alignui.css --watch",
    "ui": "bun ./src/main.ts ui",
    "ui:dev": "bun run src/web/dev.ts",
    "ui:serve": "bun ./src/main.ts ui --serve",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun run build:ui && bun run typecheck && bun test"
  },
  "devDependencies": {
    "@alignui/cli": "^0.0.17",
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "bun-types": "^1.3.13",
    "portless": "^0.13.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "@clack/core": "^1.3.0",
    "@clack/prompts": "^1.3.0",
    "@heroui/react": "^3.2.1",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@remixicon/react": "^4.9.0",
    "@tanstack/react-router": "^1.169.2",
    "chalk": "^5.6.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "hono": "^4.12.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  }
}
